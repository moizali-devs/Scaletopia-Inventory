SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Clay outbound webhook target for the "Push to Clay" action.
# Server-only — read via process.env in lib/clay/push-to-clay.ts, never exposed to the client
# (do NOT prefix with NEXT_PUBLIC_). Set in .env.local and in the Vercel project env.
CLAY_WEBHOOK_URL=
